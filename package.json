{
  "scripts": {
    "dev": "concurrently \"vite\" \"web-ext run --target chromium --arg=--auto-open-devtools-for-tabs --source-dir=./dist --config=./web-ext-config.mjs\"",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "test": "vitest --run",
    "test:ui": "vitest --ui",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.2.1",
    "@testing-library/jest-dom": "^6.1.0",
    "@testing-library/react": "^16.3.0",
    "@types/chrome": "^0.1.43",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.0",
    "@vitest/ui": "^4.0.0",
    "concurrently": "^9.1.0",
    "jsdom": "^27.2.0",
    "typescript": "^5.6.0",
    "vite": "^7.2.2",
    "vitest": "^4.0.0",
    "web-ext": "^9.1.0"
  },
  "name": "focus-watch",
  "version": "1.0.0",
  "description": "focus-watch - Chrome Extension",
  "type": "module",
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  }
